{
  "datasets": [
    {
      "name": "sales_data",
      "displayName": "Sales Data",
      "config": {
        "version": "1.1",
        "source": "fmcg.gold.vw_fact_orders_enriched",
        "dimensions": [
          {
            "name": "date",
            "expr": "date"
          },
          {
            "name": "year",
            "expr": "year"
          },
          {
            "name": "quarter",
            "expr": "CONCAT('Q', QUARTER(date))"
          },
          {
            "name": "month",
            "expr": "month__name"
          },
          {
            "name": "month_number",
            "expr": "MONTH(date)"
          },
          {
            "name": "customer",
            "expr": "customer"
          },
          {
            "name": "market",
            "expr": "market"
          },
          {
            "name": "channel",
            "expr": "channel"
          },
          {
            "name": "product",
            "expr": "product"
          },
          {
            "name": "category",
            "expr": "category"
          },
          {
            "name": "division",
            "expr": "division"
          }
        ],
        "measures": [
          {
            "name": "total_sales",
            "expr": "SUM(total_amount_inr)"
          },
          {
            "name": "total_quantity",
            "expr": "SUM(sold_quantity)"
          }
        ]
      }
    },
    {
      "name": "top_5_products",
      "displayName": "Top 5 Products",
      "queryLines": [
        "SELECT\n",
        "  product,\n",
        "  SUM(total_amount_inr) AS total_sales\n",
        "FROM\n",
        "  fmcg.gold.vw_fact_orders_enriched\n",
        "GROUP BY\n",
        "  product\n",
        "ORDER BY\n",
        "  total_sales DESC\n",
        "LIMIT 5"
      ]
    },
    {
      "name": "top_5_customers",
      "displayName": "Top 5 Customers",
      "queryLines": [
        "SELECT\n",
        "  customer,\n",
        "  SUM(total_amount_inr) AS total_sales\n",
        "FROM\n",
        "  fmcg.gold.vw_fact_orders_enriched\n",
        "GROUP BY\n",
        "  customer\n",
        "ORDER BY\n",
        "  total_sales DESC\n",
        "LIMIT 5"
      ]
    },
    {
      "name": "cumulative_orders",
      "displayName": "Cumulative Orders Growth",
      "queryLines": [
        "SELECT\n",
        "  date,\n",
        "  COUNT(*) AS daily_orders,\n",
        "  SUM(COUNT(*)) OVER (ORDER BY date) AS cumulative_orders\n",
        "FROM\n",
        "  fmcg.gold.vw_fact_orders_enriched\n",
        "GROUP BY\n",
        "  date\n",
        "ORDER BY\n",
        "  date"
      ]
    },
    {
      "name": "top_10_products",
      "displayName": "Top 10 Products by Revenue",
      "queryLines": [
        "SELECT\n",
        "  product,\n",
        "  SUM(total_amount_inr) AS total_revenue\n",
        "FROM\n",
        "  fmcg.gold.vw_fact_orders_enriched\n",
        "GROUP BY\n",
        "  product\n",
        "ORDER BY\n",
        "  total_revenue DESC\n",
        "LIMIT 10"
      ],
      "catalog": "fmcg",
      "schema": "gold"
    }
  ],
